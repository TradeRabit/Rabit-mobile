{
  "expo": {
    "name": "Rabit-mobile",
    "slug": "Rabit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Rabit icon/Icon.png",
    "scheme": "rabitmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#010101",
        "foregroundImage": "./assets/Rabit icon/Icon.png",
        "backgroundImage": "./assets/Rabit icon/Icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "adjustResize",
      "package": "com.foundoneblock.Rabitmobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/Rabit fav icon all size/icon + background 48x48.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/Rabit icon/Icon.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#EFEFEF",
          "dark": {
            "image": "./assets/Rabit icon/Icon white.png",
            "backgroundColor": "#010101"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "890a4253-50f7-4cf0-bf3a-c71c16eb5561"
      }
    },
    "owner": "foundoneblock"
  }
}
